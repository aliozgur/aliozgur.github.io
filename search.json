---
layout: null
---
[{% for post in site.posts %}{"id":{{ forloop.index }},"title":{{ post.title | jsonify }},"subtitle":{{ post.subtitle | default: "" | jsonify }},"url":{{ post.url | jsonify }},"date":{{ post.date | date: "%B %d, %Y" | jsonify }},"tags":{{ post.tags | join: " " | jsonify }},"date_ts":{{ post.date | date: "%s" | plus: 0 }},"excerpt":{{ post.excerpt | strip | jsonify }}}{% unless forloop.last %},{% endunless %}{% endfor %}]
